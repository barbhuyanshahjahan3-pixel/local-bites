# Server
PORT=5000
NODE_ENV=development
CLIENT_URLS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/localbites?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Initial Super Admin (used only by the one-time seed script)
SUPER_ADMIN_EMAIL=owner@localbites.app
SUPER_ADMIN_TEMP_PASSWORD=ChangeMeOnFirstLogin!1

# Platform defaults
DEFAULT_COMMISSION_PERCENT=15
DEFAULT_DELIVERY_CHARGE=30
