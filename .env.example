# These are read at BUILD time by all 5 apps (Vite inlines them into the
# bundle). Set them as Environment Variables in the Netlify UI for your
# site — Site configuration > Environment variables — not in this file.
# This file is just a reference for what to set.

# URL of your deployed backend (Render), e.g. https://local-bites-api.onrender.com
VITE_API_URL=

# Razorpay publishable key (used only by the customer app checkout)
VITE_RAZORPAY_KEY_ID=
